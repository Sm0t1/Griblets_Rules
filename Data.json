    {
      "rules": [
        {
          "id": "_qtw9wf8",
          "title": "Fortify (Passive)",
          "desc": "When you would activate a unit, you can instead choose to fortify that unit. A unit can't activate and fortify. Place a fortify token next to that unit if it does not already have one. Once per round, you may activate a unit with a fortify token without spending an activation, consuming the fortify token. When a unit with fortify activates, it can't move more than 2”. If a unit activates normally, it loses its token."
        },
        {
          "id": "_rztauop",
          "title": "Duck (Manoeuver)",
          "desc": "Choose an allied unit engaged in melee. Until the end of the turn, that unit no longer counts as engaged in melee for the purpose of gaining cover from ranged units."
        },
        {
          "id": "_djux3k3",
          "title": "Hold Ground (Manoeuver)",
          "desc": "Choose an enemy unit that is attempting to move within 1” of an allied unit. That unit can either choose to not enter within 1” of that unit, or that unit can trigger an action, however they can’t move during that action, and any attacks can only target the triggering unit. Ranged attacks made this way don’t suffer from inaccurate."
        },
        {
          "id": "_mcudds7",
          "title": "Subterran traversal (Manoeuver)",
          "desc": "Choose an allied unit. When it activates, it can only move, but ignores all terrain and models, and can move an additional 2\"."
        }
      ],
