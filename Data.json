    {
      "rules": [
        {
          "id": "_2ofcor4",
          "title": "Enrage (Passive)",
          "desc": "Whenever a unit takes damage, place an enrage token on that unit if it does not already have one. At the end of your turn, remove all enrage tokens from all units. During your turn, when you activate a unit with an enrage token, it can move an additional 1d3”. If the unit attacks, it may reroll each attack die once."
        },
        {
          "id": "_j1fqx9g",
          "title": "Prod (Manoeuver)",
          "desc": "Choose a unit within 3” of an allied unit. That unit receives 1 wound."
        },
        {
          "id": "_ffso875",
          "title": "Thrash (Manoeuver)",
          "desc": "Choose an allied unit with an enrage token. Remove the token. That unit is able to be activated an additional time this turn, with normal activation cost."
        },
        {
          "id": "_zpd9n26",
          "title": "Roar (Manoeuver)",
          "desc": "Choose an allied unit. Inflict X against all enemy units within 6” of that unit, where X is 5 + that units point cost. All inflicted units are stunned."
        }
      ],
